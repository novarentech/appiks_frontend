# URL where NextAuth.js is hosted (e.g., http://localhost:3000 or https://yourdomain.com)
NEXTAUTH_URL=

# Trust the host header for NextAuth.js (set to true in production)
AUTH_TRUST_HOST=

# Base URL for your API endpoints
API_BASE_URL=

# Secret key for signing JWT tokens
JWT_SECRET=

# Secret key for NextAuth.js session encryption
NEXTAUTH_SECRET=

# Trust the host header for NextAuth.js (alternative to AUTH_TRUST_HOST)
NEXTAUTH_TRUST_HOST=